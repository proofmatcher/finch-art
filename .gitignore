# Dependencies
node_modules/
*/node_modules/

# Build outputs
client/dist/
client/.vite/

# Environment files — keep .env.production (public API URL only, no secrets)
.env
.env.local
server/.env
client/.env

# Database — NOT committed (Railway will init fresh DB on first run)
server/*.db
server/*.db-shm
server/*.db-wal
server/db/*.db
server/db/*.sqlite

# Uploads — YES committed (artwork images & Porter photos must be in repo)
# server/uploads/ is tracked

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/

# Vercel
.vercel/
